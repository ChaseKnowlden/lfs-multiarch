# Copy this file to .env and fill in your token.
# .env is listed in .gitignore and will never be committed.
#
# GitHub Personal Access Token (fine-grained or classic).
# Required scopes: none (public repo read is enough — leave all boxes unchecked).
# Without a token: 60 requests/hour.  With a token: 5 000 requests/hour.
#
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=
